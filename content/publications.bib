@inproceedings{qian2026likelihood,
  title = {Likelihood Matching for Diffusion Models},
  author = {Qian, L. and Su, W. and Huang, Y. and Chen, S.X.},
  booktitle = {Proceedings of the 43rd International Conference on Machine Learning},
  year = {2026},
  volume = {306},
  note = {Accepted},
  url = {https://arxiv.org/abs/2508.03636},
  preprint = {https://arxiv.org/abs/2508.03636},
  pdf = {/papers/likelihood-matching-diffusion-models.pdf},
  preview = {likelihood-matching.png},
  abstract = {We propose a Likelihood Matching approach for training diffusion models by establishing an equivalence between the likelihood of the target data distribution and a likelihood along the sample path of the reverse diffusion. A quasi-likelihood approximation matches conditional mean and covariance for reverse transition densities, allowing score and Hessian functions to be estimated jointly. The paper introduces a stochastic sampler using both score and Hessian information, proves consistency and non-asymptotic convergence guarantees, and validates the method through empirical and simulation studies.},
  keywords = {Diffusion Models, Likelihood, Statistical Learning, Generative Models}
}

@misc{su2026blocksignals,
  title = {High-dimensional Clustering and Signal Recovery under Block Signals},
  author = {Su, W. and Qiu, Y.},
  year = {2026},
  journal = {Preprint},
  note = {Moderate revision for Journal of the American Statistical Association.},
  url = {https://arxiv.org/abs/2504.08332},
  preprint = {https://arxiv.org/abs/2504.08332},
  pdf = {/papers/high-dimensional-clustering-block-signals.pdf},
  preview = {high-dimensional-clustering.png},
  abstract = {This paper studies computationally efficient methods and minimax optimality for high-dimensional clustering and signal recovery under block signal structures. It proposes cross-block feature aggregation PCA for sparse block signals and moving average PCA for dense block signals, allowing non-Gaussian data, heterogeneous variances, and non-diagonal covariance matrices. The paper establishes statistical and computational minimax lower bounds, shows that the proposed methods attain computational minimax optimality in their respective regimes, and demonstrates the approach through simulations and a global temperature-change case study.},
  keywords = {High-dimensional Statistics, Clustering, Signal Recovery, Block Signals, Computational Constraints}
}

@article{su2026glider,
  title = {Glider Path Design and Control for Reconstructing Three-Dimensional Structures of Oceanic Mesoscale Eddies},
  author = {Su, W. and E, X. and Jing, Z. and Chen, S.X.},
  year = {2026},
  journal = {Proceedings of the Royal Society A},
  volume = {482},
  number = {2333},
  pages = {20250533},
  doi = {10.1098/rspa.2025.0533},
  url = {https://royalsocietypublishing.org/rspa/article/482/2333/20250533/480655/Glider-path-design-and-control-for-reconstructing},
  pdf = {/papers/glider-path-design-mesoscale-eddies.pdf},
  preview = {glider-path-design.png},
  abstract = {Underwater gliders are autonomous in situ platforms used in oceanographic research. This work develops a framework for reconstructing the three-dimensional hydrographic structure of mesoscale eddies by combining thin plate spline interpolation, glider path design, and adaptive path control under realistic ocean currents. Simulated and real eddy evaluations show that the proposed interpolation improves temperature and salinity reconstruction, the designed paths balance coverage and sampling efficiency, and the control algorithm helps gliders maintain planned trajectories and return safely under strong currents.},
  keywords = {Ocean Data Assimilation, Glider Path Design, Mesoscale Eddies, Adaptive Control}
}

@article{du2025threedimensional,
  title = {Three-Dimensional Observations of a Mesoscale Eddy in the Kuroshio Extension Based on Multiple Platforms},
  author = {Du, T. and Zhang, Y. and Su, W. and Jing, Z. and Chen, Z. and Qiu, Y. and Zhang, H. and Yang, S. and Ma, W.},
  year = {2025},
  journal = {Scientific Data},
  volume = {12},
  pages = {2013},
  doi = {10.1038/s41597-025-06267-z},
  url = {https://www.nature.com/articles/s41597-025-06267-z},
  pdf = {/papers/mesoscale-eddy-kuroshio-extension.pdf},
  preview = {mesoscale-eddy.png},
  abstract = {This data descriptor reports an eddy-oriented survey of a cyclonic eddy in the Kuroshio Extension during September 2024. The campaign synchronized in situ sampling with the SWOT mission and combined shipboard measurements with observations from seven autonomous underwater gliders and twenty surface drifters. The resulting high-resolution, wide-coverage dataset captures the eddy's three-dimensional structure and supports SWOT calibration, eddy transport estimation, and validation of eddy-resolving ocean forecasting systems.},
  keywords = {Ocean Observation, Mesoscale Eddies, Kuroshio Extension, SWOT, Gliders}
}

@article{weng2025enkf,
  title = {Using EnKF Data Assimilation to Improve Predictions of Volcanic Ash Dispersion},
  author = {Weng, Z. and Zhu, L. and Li, J. and Zhang, Y. and Liu, X. and Su, W. and Sun, H. and Li, X.},
  year = {2025},
  journal = {Journal of Geophysical Research: Atmospheres},
  volume = {130},
  pages = {e2024JD042215},
  doi = {10.1029/2024JD042215},
  url = {https://agupubs.onlinelibrary.wiley.com/doi/10.1029/2024JD042215},
  pdf = {/papers/volcanic-ash-enkf-data-assimilation.pdf},
  preview = {volcanic-ash.png},
  abstract = {This study presents an ensemble Kalman filter data assimilation method that combines satellite observations with the HYSPLIT volcanic ash dispersion model. Using the 2010 Eyjafjallajokull eruptions as a case study, the method improves forecasts of ash spatial distribution, mass loading, and cloud top height by continuously assimilating satellite observations. The results show that data assimilation can address poor model initialization and sometimes outperform corresponding satellite retrievals.},
  keywords = {Ensemble Kalman Filter, Data Assimilation, Volcanic Ash, Atmospheric Science}
}

@article{su2024carbonflux,
  title = {A New Global Carbon Flux Estimation Methodology by Assimilation of Both In Situ and Satellite CO2 Observations},
  author = {Su, W. and Wang, B. and Chen, H. and Zhu, L. and Zheng, X. and Chen, S.X.},
  year = {2024},
  journal = {npj Climate and Atmospheric Science},
  volume = {7},
  pages = {287},
  doi = {10.1038/s41612-024-00824-w},
  url = {https://www.nature.com/articles/s41612-024-00824-w},
  pdf = {/papers/carbon-flux-assimilation-co2.pdf},
  preview = {carbon-flux.png},
  abstract = {This paper develops a multi-observation carbon assimilation system that integrates both satellite and ground-based CO2 observations. The method modifies the ensemble Kalman filter with different inflation factors for different observation-error types, addressing heterogeneity between satellite and in situ data. In validation experiments, the carbon flux derived from the system reduced error compared with existing products and produced terrestrial and ocean carbon-sink estimates consistent with Global Carbon Project benchmarks.},
  keywords = {Carbon Flux, Data Assimilation, Ensemble Kalman Filter, Satellite Observations, Climate Science}
}

@inproceedings{tong2023domaingeneralization,
  title = {Distribution Free Domain Generalization},
  author = {Tong, P. and Su, W. and Li, H. and Ding, J. and Zhan, H. and Chen, S.X.},
  year = {2023},
  booktitle = {Proceedings of the 40th International Conference on Machine Learning},
  volume = {202},
  pages = {34369--34378},
  url = {https://proceedings.mlr.press/v202/tong23a.html},
  pdf = {/papers/distribution-free-domain-generalization.pdf},
  preview = {domain-generalization.png},
  abstract = {This paper proposes a Distribution Free Domain Generalization procedure for classification. The method standardizes cross-domain and cross-class discrepancy statistics to avoid dominance by a few domains in training. It reformulates discrepancy through pairwise two-sample test statistics, provides distribution-free standardized metrics, establishes a theoretical generalization bound for multi-class classification, and demonstrates strong empirical performance with fewer hyperparameters.},
  keywords = {Domain Generalization, Machine Learning, Distribution-free Methods}
}
